{
  "name": "ema-servidor",
  "version": "1.0.0",
  "description": "Servidor da Estação Meteorológica Automática de Três Lagoas",
  "main": "./dist/server.js",
  "repository": "https://github.com/henryifms/servidor-ema.git",
  "author": "Henry Thomaz Oliveira Campos, Kleber Rodrigo Penteado",
  "license": "MIT",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "tsx watch src/server.ts",
    "migrate": "sequelize db:migrate",
    "migrate:undo": "sequelize db:migrate:undo:all",
    "seed": "yarn sequelize db:seed:all",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "queue": "tsx watch src/queue.ts"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "bee-queue": "^2.0.0",
    "cors": "^2.8.6",
    "date-fns": "^4.1.0",
    "dotenv": "^16.4.5",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.13.0",
    "pg-hstore": "^2.3.4",
    "redis": "^4.7.0",
    "resend": "^6.9.3",
    "sequelize": "^6.37.5",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "yup": "^1.6.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^25.4.0",
    "@types/sequelize": "^4.28.20",
    "@types/swagger-jsdoc": "^6",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.4.0",
    "jiti": "^2.6.1",
    "nodemon": "^3.1.0",
    "prettier": "^3.3.0",
    "sequelize-cli": "^6.6.2",
    "tsx": "^4.19.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0"
  },
  "packageManager": "yarn@4.13.0"
}
